    "textTertiary": "#00994d",
    "borderPrimary": "#533483",
    "borderSecondary": "#e94560",
    "accent": "#e94560",
    "accentHover": "#ff6b8a",
    "accentText": "#ffffff",
    "success": "#00ff88",
    "warning": "#ffaa00",
    "error": "#ff0044",
    "info": "#00a8ff",
    "hover": "#16213e",
    "active": "#0f3460",
    "codeBg": "#16213e",
    "codeText": "#00ff88",
    "blockquoteBorder": "#e94560",
